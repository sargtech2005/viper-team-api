<%- contentFor('style') %>
<style>
.key-card{background:var(--bg-card);border:1.5px solid var(--border);border-radius:var(--radius-lg);padding:20px;margin-bottom:12px;transition:border-color var(--transition)}
.key-card:hover{border-color:#c4b5fd}
.key-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.key-label-text{font-weight:700;font-size:.93rem;margin-bottom:3px}
.key-meta{font-size:.76rem;color:var(--text-muted)}
.key-actions{display:flex;gap:7px;align-items:center;flex-wrap:wrap}
.gen-box{background:var(--bg-2);border:2px dashed var(--border);border-radius:var(--radius-lg);padding:32px 20px;text-align:center;margin-bottom:24px;transition:border-color var(--transition)}
.gen-box:hover{border-color:var(--purple)}
.gen-box-icon{width:52px;height:52px;background:var(--purple-bg);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
.gen-box-icon svg{color:var(--purple)}
.gen-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;max-width:460px;margin:0 auto}
.masked{letter-spacing:2px}
</style>

<div class="dashboard-layout">
  <%- include('../partials/sidebar', { active: 'api-keys' }) %>
  <div class="dashboard-main">
    <div class="page-header">
      <h2>API Keys</h2>
      <p>Generate keys to authenticate your requests. Maximum 5 active keys.</p>
    </div>

    <div class="gen-box">
      <div class="gen-box-icon"><%- icon('plus', 24) %></div>
      <h3 style="margin-bottom:8px">Generate a New Key</h3>
      <p style="font-size:.86rem;margin-bottom:20px">Give it a label so you know which project it's for.</p>
      <div class="gen-row">
        <input type="text" id="keyLabel" class="form-input" placeholder="e.g. My WhatsApp Bot" style="max-width:280px" maxlength="80" />
        <button class="btn btn-primary" onclick="generateKey()"><%- icon('zap',15) %> Generate</button>
      </div>
    </div>

    <div id="keysList">
      <% if (!keys.length) { %>
        <div style="text-align:center;padding:40px;color:var(--text-muted)">
          <p>No API keys yet. Generate one above.</p>
        </div>
      <% } else { %>
        <% keys.forEach(k => { %>
        <div class="key-card" id="keycard-<%= k.id %>">
          <div class="key-header">
            <div>
              <div class="key-label-text"><%= k.label %></div>
              <div class="key-meta">
                Created <%= new Date(k.created_at).toLocaleDateString() %>
                <% if (k.last_used) { %> &nbsp;·&nbsp; Last used <%= new Date(k.last_used).toLocaleDateString() %><% } %>
              </div>
            </div>
            <div class="key-actions">
              <span class="badge <%= k.is_active ? 'badge-green':'badge-red' %>"><%= k.is_active ? 'Active':'Inactive' %></span>
              <button class="btn btn-outline btn-sm" onclick="viperCopy('<%= k.key_value %>','Copied!')"><%- icon('copy',13) %> Copy</button>
              <button class="btn btn-danger btn-sm" onclick="deleteKey(<%= k.id %>)"><%- icon('trash',13) %></button>
            </div>
          </div>
          <div class="api-key-row">
            <div class="api-key-val masked" id="kv-<%= k.id %>"><%= k.key_value.substring(0,10) %>••••••••••••••••••••••••••••</div>
            <button class="btn btn-outline btn-sm" onclick="toggleReveal(<%= k.id %>, '<%= k.key_value %>')"><%- icon('eye',14) %> Reveal</button>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>

    <div class="card mt-4">
      <h4 style="margin-bottom:14px">How to use your key</h4>
      <div class="code-block">
        <button class="copy-btn" onclick="viperCopy('Authorization: Bearer YOUR_API_KEY','Copied!')"><%- icon('copy',11) %> Copy</button>
        <pre style="color:#86efac">// Option 1 — Header (recommended)
fetch('https://viper-api.name.ng/api/v1/utility/uuid', {
  headers: { 'Authorization': 'Bearer YOUR_API_KEY' }
})

// Option 2 — Query param
fetch('https://viper-api.name.ng/api/v1/utility/uuid?apikey=YOUR_API_KEY')</pre>
      </div>
    </div>
  </div>
</div>

<%- contentFor('script') %>
<script>
async function generateKey() {
  const label = document.getElementById('keyLabel').value.trim() || 'My API Key';
  const r = await fetch('/dashboard/api-keys/generate', {
    method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({label})
  });
  const d = await r.json();
  if (!d.success) return viperAlert(d.error, 'error');
  viperAlert('API key generated! Copy it from your list below.', 'success');
  setTimeout(() => location.reload(), 1400);
}
async function deleteKey(id) {
  const ok = await viperConfirm('Delete this API key? Apps using it will stop working immediately.','Delete Key');
  if (!ok) return;
  const r = await fetch('/dashboard/api-keys/'+id, {method:'DELETE'});
  const d = await r.json();
  if (!d.success) return viperAlert(d.error, 'error');
  document.getElementById('keycard-'+id)?.remove();
  viperToast('API key deleted.', 'success');
}
function toggleReveal(id, full) {
  const el  = document.getElementById('kv-'+id);
  const btn = el.nextElementSibling;
  if (el.classList.contains('masked')) {
    el.textContent = full; el.classList.remove('masked'); btn.innerHTML = '<%- icon('eye-off',14).replace(/'/g,"\\'") %> Hide';
  } else {
    el.textContent = full.substring(0,10)+'••••••••••••••••••••••••••••'; el.classList.add('masked'); btn.innerHTML = '<%- icon('eye',14).replace(/'/g,"\\'") %> Reveal';
  }
}
</script>
