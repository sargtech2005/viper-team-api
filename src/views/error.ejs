<style>
.error-title{font-size:1.5rem;font-weight:700;margin:12px 0 8px;color:var(--text)}
.error-page{background:var(--bg-2)}
</style>
<div class="error-page">
  <div style="text-align:center;padding:80px 20px">
    <div class="error-code"><%= code||404 %></div>
    <h2 class="error-title"><%= title||'Page Not Found' %></h2>
    <p style="max-width:400px;margin:0 auto 28px"><%= message||'The page you are looking for does not exist.' %></p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a href="/" class="btn btn-primary"><%- icon('home',16) %> Go Home</a>
      <a href="/docs" class="btn btn-outline"><%- icon('book',16) %> View Docs</a>
    </div>
  </div>
</div>
