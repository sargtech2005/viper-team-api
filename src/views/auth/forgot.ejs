
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo-wrap"><%- icon('mail', 26) %></div>
      <h1 class="auth-title">Forgot password</h1>
      <p class="auth-subtitle">Enter your email and we'll send a reset link.</p>
    </div>
    <% if (error) { %><div class="alert alert-error"><%- icon('alert-triangle',15) %> <%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><%- icon('check-circle',15) %> <%= success %></div><% } %>
    <% if (!success) { %>
    <form class="auth-form" method="POST" action="/forgot" id="forgotForm" novalidate>
      <div class="form-group">
        <label class="form-label" for="email">Email address</label>
        <input class="form-input" type="email" id="email" name="email"
          placeholder="The email on your account" required autocomplete="email" />
      </div>
      <button class="btn btn-primary btn-block" type="submit" id="forgotBtn">
        <%- icon('mail',16) %> Send reset link
      </button>
    </form>
    <% } %>
    <div class="auth-footer"><a href="/login"><%- icon('arrow-right',14) %> Back to sign in</a></div>
  </div>
</div>

<script>
const f=document.getElementById('forgotForm');
if(f) f.addEventListener('submit',function(e){
  if(!document.getElementById('email').value.trim()){e.preventDefault();viperAlert('Please enter your email.','warning');return;}
  const b=document.getElementById('forgotBtn'); b.disabled=true; b.innerHTML='Sending...';
});
</script>
