<!-- Viper Alert System — no browser dialogs ever -->
<div id="viperModal" class="viper-modal-overlay" style="display:none" role="dialog" aria-modal="true">
  <div class="viper-modal" id="viperModalBox">
    <div class="viper-modal-icon" id="viperModalIcon">
      <!-- icon injected by JS -->
    </div>
    <h3 class="viper-modal-title"  id="viperModalTitle">Notice</h3>
    <p  class="viper-modal-message" id="viperModalMessage"></p>
    <div class="viper-modal-actions" id="viperModalActionsAlert">
      <button class="btn btn-primary" id="viperModalOk">Got it</button>
    </div>
    <div class="viper-modal-actions" id="viperModalActionsConfirm" style="display:none">
      <button class="btn btn-outline" id="viperModalCancel">Cancel</button>
      <button class="btn btn-danger"  id="viperModalConfirm">Confirm</button>
    </div>
  </div>
</div>
