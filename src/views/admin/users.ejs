<style>
.admin-main{padding:28px 24px}
@media(max-width:600px){.admin-main{padding:16px}}

/* ── Search bar ── */
.users-toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:18px}
.users-search{display:flex;align-items:center;gap:0;flex:1;min-width:200px;max-width:360px}
.users-search input{flex:1;border-radius:var(--radius-sm) 0 0 var(--radius-sm);border-right:none}
.users-search button{border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:0 14px;height:38px;background:var(--purple);color:#fff;border:1.5px solid var(--purple);cursor:pointer;font-size:.82rem;font-weight:600;transition:opacity .15s}
.users-search button:hover{opacity:.85}

/* ── Manage button ── */
.btn-manage{background:var(--purple-bg);color:var(--purple);border:1.5px solid var(--purple);border-radius:var(--radius-sm);padding:4px 11px;font-size:.78rem;font-weight:600;cursor:pointer;transition:all .15s;white-space:nowrap}
.btn-manage:hover{background:var(--purple);color:#fff}

/* ── Modal overlay ── */
.um-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:900;display:flex;align-items:center;justify-content:center;padding:16px;opacity:0;pointer-events:none;transition:opacity .2s ease}
.um-overlay.open{opacity:1;pointer-events:all}

/* ── Modal box ── */
.um-modal{background:var(--bg-card);border:1.5px solid var(--border);border-radius:var(--radius);width:100%;max-width:540px;max-height:90vh;overflow-y:auto;transform:translateY(20px) scale(.97);transition:transform .22s ease;box-shadow:0 20px 60px rgba(0,0,0,.45)}
.um-overlay.open .um-modal{transform:translateY(0) scale(1)}

.um-header{display:flex;align-items:center;justify-content:space-between;padding:18px 20px 14px;border-bottom:1px solid var(--border)}
.um-header h3{font-size:1rem;font-weight:700;margin:0;display:flex;align-items:center;gap:8px}
.um-close{background:none;border:none;color:var(--text-muted);cursor:pointer;padding:4px;border-radius:6px;transition:color .15s;line-height:1}
.um-close:hover{color:var(--text)}

/* ── User info strip ── */
.um-user-strip{padding:14px 20px;background:var(--bg-2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px}
.um-avatar{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--green));display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:700;color:#fff;flex-shrink:0}
.um-user-info{flex:1;min-width:0}
.um-user-info .um-name{font-weight:700;font-size:.95rem;margin:0 0 2px}
.um-user-info .um-meta{font-size:.77rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.um-badges{display:flex;gap:6px;flex-wrap:wrap}

/* ── Sections ── */
.um-body{padding:16px 20px;display:flex;flex-direction:column;gap:16px}
.um-section{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px 16px}
.um-section-title{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin:0 0 12px;display:flex;align-items:center;gap:6px}
.um-section-title svg{color:var(--purple)}

/* ── Stat row ── */
.um-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.um-stat{text-align:center;padding:8px 6px;background:var(--bg-card);border-radius:var(--radius-sm);border:1px solid var(--border)}
.um-stat .val{font-size:1.1rem;font-weight:800;color:var(--text)}
.um-stat .lbl{font-size:.68rem;color:var(--text-muted);margin-top:2px}

/* ── Action rows ── */
.um-action-row{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}
.um-action-row:last-child{border-bottom:none;padding-bottom:0}
.um-action-label{font-size:.83rem;font-weight:600;color:var(--text);flex:1}
.um-action-sub{font-size:.74rem;color:var(--text-muted);margin-top:2px}

/* ── Inline credit input ── */
.um-credit-row{display:flex;align-items:center;gap:8px;width:100%}
.um-credit-row input{flex:1;font-size:.83rem;padding:6px 10px}
.um-credit-row select{font-size:.83rem;padding:6px 8px;background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm);color:var(--text)}
.um-credit-row button{white-space:nowrap}

/* ── Plan select row ── */
.um-plan-row{display:flex;align-items:center;gap:8px;width:100%}
.um-plan-row select{flex:1;font-size:.83rem;padding:6px 10px;background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm);color:var(--text)}

/* ── Danger zone ── */
.um-section.danger{border-color:rgba(239,68,68,.3);background:rgba(239,68,68,.04)}
.um-section.danger .um-section-title{color:#ef4444}
.btn-danger{background:rgba(239,68,68,.12);color:#ef4444;border:1.5px solid rgba(239,68,68,.35);border-radius:var(--radius-sm);padding:5px 13px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .15s}
.btn-danger:hover{background:#ef4444;color:#fff;border-color:#ef4444}
.btn-warn{background:rgba(245,158,11,.1);color:#f59e0b;border:1.5px solid rgba(245,158,11,.35);border-radius:var(--radius-sm);padding:5px 13px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .15s}
.btn-warn:hover{background:#f59e0b;color:#fff}
.btn-success-sm{background:rgba(16,185,129,.1);color:var(--green);border:1.5px solid rgba(16,185,129,.3);border-radius:var(--radius-sm);padding:5px 13px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .15s}
.btn-success-sm:hover{background:var(--green);color:#fff}
</style>

<div class="admin-main">
  <%- include('../partials/admin-nav', { adminActive: 'users' }) %>

  <div class="page-header flex-between flex-wrap gap-1" style="margin-bottom:16px">
    <div><h2>Users</h2><p>Total: <strong><%= total %></strong> account<%= total!==1?'s':'' %>.<%= search ? ` Showing results for "<strong>${search}</strong>"` : '' %></p></div>
  </div>

  <!-- Search -->
  <div class="users-toolbar">
    <form method="GET" action="/admin/users" class="users-search">
      <input type="text" name="q" value="<%= search %>" placeholder="Search username or email…">
      <button type="submit">Search</button>
    </form>
    <% if (search) { %><a href="/admin/users" class="btn btn-outline btn-sm">Clear</a><% } %>
  </div>

  <div class="card" style="padding:0">
    <div class="table-wrap"><table>
      <thead>
        <tr>
          <th>ID</th><th>Username</th><th>Email</th><th>Plan</th>
          <th>Calls</th><th>Credits</th><th>Role</th><th>Status</th>
          <th>Joined</th><th>Manage</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr id="urow-<%= u.id %>">
          <td style="color:var(--text-muted)">#<%= u.id %></td>
          <td><strong><%= u.username %></strong></td>
          <td style="font-size:.78rem"><%= u.email %></td>
          <td><span class="badge badge-blue" id="uplan-<%= u.id %>"><%= u.plan_name||'Free' %></span></td>
          <td id="ucalls-<%= u.id %>"><%= (u.api_calls_used||0).toLocaleString() %></td>
          <td id="ucredits-<%= u.id %>"><%= (u.credit_balance||0).toLocaleString() %></td>
          <td><span class="badge <%= u.role==='admin'?'badge-purple':'badge-gray' %>" id="urole-<%= u.id %>"><%= u.role %></span></td>
          <td><span class="badge <%= u.is_active?'badge-green':'badge-red' %>" id="ustatus-<%= u.id %>"><%= u.is_active?'Active':'Banned' %></span></td>
          <td style="font-size:.74rem;color:var(--text-muted)"><%= new Date(u.created_at).toLocaleDateString() %></td>
          <td>
            <button class="btn-manage" onclick="openUserModal(<%= u.id %>)">⚙ Manage</button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table></div>
  </div>

  <!-- Pagination -->
  <% if (totalPages>1) { %>
  <div style="display:flex;gap:7px;justify-content:center;margin-top:16px;flex-wrap:wrap">
    <% for(let i=1;i<=totalPages;i++){ %>
    <a href="?page=<%= i %><%= search?'&q='+encodeURIComponent(search):'' %>" class="btn <%= i===page?'btn-primary':'btn-outline' %> btn-sm"><%= i %></a>
    <% } %>
  </div>
  <% } %>
</div>

<!-- ══ User Management Modal ═══════════════════════════════════════════════════ -->
<div class="um-overlay" id="umOverlay" onclick="closeIfBg(event)">
  <div class="um-modal" id="umModal">

    <div class="um-header">
      <h3 id="umTitle">User Management</h3>
      <button class="um-close" onclick="closeUserModal()" title="Close">✕</button>
    </div>

    <!-- User strip -->
    <div class="um-user-strip" id="umStrip">
      <div class="um-avatar" id="umAvatar">?</div>
      <div class="um-user-info">
        <div class="um-name" id="umName">—</div>
        <div class="um-meta" id="umEmail">—</div>
      </div>
      <div class="um-badges">
        <span class="badge" id="umRoleBadge">—</span>
        <span class="badge" id="umStatusBadge">—</span>
      </div>
    </div>

    <div class="um-body">

      <!-- Stats -->
      <div class="um-section">
        <div class="um-section-title">📊 Account Stats</div>
        <div class="um-stats">
          <div class="um-stat"><div class="val" id="umCallsVal">—</div><div class="lbl">API Calls</div></div>
          <div class="um-stat"><div class="val" id="umCreditsVal">—</div><div class="lbl">Credits</div></div>
          <div class="um-stat"><div class="val" id="umJoinedVal">—</div><div class="lbl">Joined</div></div>
        </div>
      </div>

      <!-- Plan Management -->
      <div class="um-section">
        <div class="um-section-title">📦 Change Plan</div>
        <div class="um-plan-row">
          <select id="umPlanSelect">
            <% plans.forEach(p => { %>
            <option value="<%= p.id %>"><%= p.name %> — ₦<%= p.price_ngn.toLocaleString() %></option>
            <% }) %>
          </select>
          <button class="btn-success-sm" onclick="changePlan()">Apply Plan</button>
        </div>
      </div>

      <!-- Credits -->
      <div class="um-section">
        <div class="um-section-title">💳 Adjust Credits</div>
        <div class="um-credit-row">
          <select id="umCreditOp">
            <option value="add">➕ Add</option>
            <option value="deduct">➖ Deduct</option>
          </select>
          <input type="number" id="umCreditAmt" placeholder="Amount" min="1" style="width:90px">
          <input type="text" id="umCreditReason" placeholder="Reason (optional)" style="flex:1">
          <button class="btn btn-sm btn-primary" onclick="adjustCredits()">Apply</button>
        </div>
      </div>

      <!-- Controls -->
      <div class="um-section">
        <div class="um-section-title">🔧 User Controls</div>

        <div class="um-action-row">
          <div>
            <div class="um-action-label">Ban / Unban User</div>
            <div class="um-action-sub">Block or restore access to the platform</div>
          </div>
          <button id="umBanBtn" class="btn-warn" onclick="toggleBan()">Ban</button>
        </div>

        <div class="um-action-row">
          <div>
            <div class="um-action-label">Reset API Call Limit</div>
            <div class="um-action-sub">Sets api_calls_used back to 0</div>
          </div>
          <button class="btn-success-sm" onclick="resetLimit()">Reset</button>
        </div>

        <div class="um-action-row">
          <div>
            <div class="um-action-label" id="umRoleLabel">Toggle Admin Role</div>
            <div class="um-action-sub">Promote to admin or demote to regular user</div>
          </div>
          <button id="umRoleBtn" class="btn btn-sm btn-outline" onclick="toggleRole()">Toggle Role</button>
        </div>
      </div>

      <!-- Danger Zone -->
      <div class="um-section danger">
        <div class="um-section-title">⚠ Danger Zone</div>
        <div class="um-action-row">
          <div>
            <div class="um-action-label" style="color:#ef4444">Delete Account</div>
            <div class="um-action-sub">Permanently removes user and all their data. Cannot be undone.</div>
          </div>
          <button class="btn-danger" onclick="deleteUser()">Delete</button>
        </div>
      </div>

    </div><!-- /um-body -->
  </div>
</div>

<!-- ══ Scripts ════════════════════════════════════════════════════════════════ -->
<script>
let _uid = null; // current modal user id
let _uActive = true;
let _uRole   = 'user';

// ── Open modal ──────────────────────────────────────────────────────────────
async function openUserModal(id) {
  _uid = id;
  document.getElementById('umTitle').textContent = 'Loading…';
  document.getElementById('umOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';

  try {
    const r = await fetch('/admin/users/' + id);
    const d = await r.json();
    if (!d.success) { viperToast(d.error || 'Failed to load user.', 'error'); closeUserModal(); return; }
    populateModal(d.user);
  } catch(e) {
    viperToast('Network error loading user.', 'error');
    closeUserModal();
  }
}

function populateModal(u) {
  _uid     = u.id;
  _uActive = u.is_active;
  _uRole   = u.role;

  const initial = (u.username || '?')[0].toUpperCase();
  document.getElementById('umAvatar').textContent  = initial;
  document.getElementById('umTitle').textContent   = 'Managing: ' + u.username;
  document.getElementById('umName').textContent    = u.username;
  document.getElementById('umEmail').textContent   = u.email + ' · #' + u.id;
  document.getElementById('umCallsVal').textContent   = (u.api_calls_used||0).toLocaleString();
  document.getElementById('umCreditsVal').textContent = (u.credit_balance||0).toLocaleString();
  document.getElementById('umJoinedVal').textContent  = new Date(u.created_at).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});

  // Role badge
  const rb = document.getElementById('umRoleBadge');
  rb.textContent = u.role;
  rb.className   = 'badge ' + (u.role === 'admin' ? 'badge-purple' : 'badge-gray');

  // Status badge
  const sb = document.getElementById('umStatusBadge');
  sb.textContent = u.is_active ? 'Active' : 'Banned';
  sb.className   = 'badge ' + (u.is_active ? 'badge-green' : 'badge-red');

  // Ban button
  const bb = document.getElementById('umBanBtn');
  bb.textContent = u.is_active ? 'Ban User' : 'Unban User';
  bb.className   = u.is_active ? 'btn-warn' : 'btn-success-sm';

  // Role button label
  document.getElementById('umRoleLabel').textContent =
    u.role === 'admin' ? 'Demote from Admin' : 'Promote to Admin';

  // Pre-select current plan in dropdown
  if (u.plan_id) {
    const sel = document.getElementById('umPlanSelect');
    if (sel) sel.value = u.plan_id;
  }

  // Clear credit inputs
  document.getElementById('umCreditAmt').value    = '';
  document.getElementById('umCreditReason').value = '';
}

// ── Close modal ─────────────────────────────────────────────────────────────
function closeUserModal() {
  document.getElementById('umOverlay').classList.remove('open');
  document.body.style.overflow = '';
  _uid = null;
}
function closeIfBg(e) {
  if (e.target === document.getElementById('umOverlay')) closeUserModal();
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeUserModal(); });

// ── Change Plan ──────────────────────────────────────────────────────────────
async function changePlan() {
  if (!_uid) return;
  const sel = document.getElementById('umPlanSelect');
  const planId   = sel.value;
  const planName = sel.options[sel.selectedIndex].text.split(' —')[0];

  const ok = await viperConfirm('Change this user\'s plan to "' + planName + '"?', 'Change Plan');
  if (!ok) return;

  const r = await fetch('/admin/users/' + _uid + '/plan', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ plan_id: planId }),
  });
  const d = await r.json();
  if (d.success) {
    viperToast('Plan changed to ' + d.plan_name + '.', 'success');
    // Update table row
    const el = document.getElementById('uplan-' + _uid);
    if (el) el.textContent = d.plan_name;
  } else {
    viperToast(d.error || 'Failed to change plan.', 'error');
  }
}

// ── Adjust Credits ───────────────────────────────────────────────────────────
async function adjustCredits() {
  if (!_uid) return;
  const op     = document.getElementById('umCreditOp').value;
  const rawAmt = parseInt(document.getElementById('umCreditAmt').value);
  const reason = document.getElementById('umCreditReason').value.trim();

  if (!rawAmt || rawAmt < 1) { viperToast('Enter a valid amount.', 'warning'); return; }

  const amount = op === 'deduct' ? -rawAmt : rawAmt;
  const label  = op === 'deduct' ? 'Deduct ' + rawAmt + ' credits?' : 'Add ' + rawAmt + ' credits?';

  const ok = await viperConfirm(label, 'Adjust Credits');
  if (!ok) return;

  const r = await fetch('/admin/users/' + _uid + '/credits', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ amount, reason }),
  });
  const d = await r.json();
  if (d.success) {
    viperToast('Credits updated. New balance: ' + d.new_balance.toLocaleString(), 'success');
    document.getElementById('umCreditsVal').textContent = d.new_balance.toLocaleString();
    const cel = document.getElementById('ucredits-' + _uid);
    if (cel) cel.textContent = d.new_balance.toLocaleString();
    document.getElementById('umCreditAmt').value    = '';
    document.getElementById('umCreditReason').value = '';
  } else {
    viperToast(d.error || 'Failed to adjust credits.', 'error');
  }
}

// ── Ban / Unban ──────────────────────────────────────────────────────────────
async function toggleBan() {
  if (!_uid) return;
  const label = _uActive ? 'Ban this user? They will lose access immediately.' : 'Unban this user and restore their access?';
  const ok = await viperConfirm(label, _uActive ? 'Ban User' : 'Unban User');
  if (!ok) return;

  const r = await fetch('/admin/users/' + _uid + '/toggle', { method: 'POST' });
  const d = await r.json();
  if (d.success) {
    _uActive = d.is_active;
    const sb = document.getElementById('umStatusBadge');
    sb.textContent = d.is_active ? 'Active' : 'Banned';
    sb.className   = 'badge ' + (d.is_active ? 'badge-green' : 'badge-red');

    const bb = document.getElementById('umBanBtn');
    bb.textContent = d.is_active ? 'Ban User' : 'Unban User';
    bb.className   = d.is_active ? 'btn-warn' : 'btn-success-sm';

    // Table row badge
    const tb = document.getElementById('ustatus-' + _uid);
    if (tb) { tb.textContent = d.is_active ? 'Active' : 'Banned'; tb.className = 'badge ' + (d.is_active ? 'badge-green' : 'badge-red'); }

    viperToast('User ' + (d.is_active ? 'unbanned' : 'banned') + '.', d.is_active ? 'success' : 'warning');
  } else {
    viperToast(d.error || 'Failed.', 'error');
  }
}

// ── Reset API Limit ──────────────────────────────────────────────────────────
async function resetLimit() {
  if (!_uid) return;
  const ok = await viperConfirm('Reset this user\'s API call count to 0?', 'Reset Limit');
  if (!ok) return;

  const r = await fetch('/admin/users/' + _uid + '/reset-limit', { method: 'POST' });
  const d = await r.json();
  if (d.success) {
    viperToast('API call limit reset to 0.', 'success');
    document.getElementById('umCallsVal').textContent = '0';
    const cel = document.getElementById('ucalls-' + _uid);
    if (cel) cel.textContent = '0';
  } else {
    viperToast(d.error || 'Failed.', 'error');
  }
}

// ── Toggle Role ──────────────────────────────────────────────────────────────
async function toggleRole() {
  if (!_uid) return;
  const isAdmin = _uRole === 'admin';
  const ok = await viperConfirm(
    isAdmin ? 'Demote this user from admin to regular user?' : 'Promote this user to admin? They will have full admin access.',
    isAdmin ? 'Demote User' : 'Promote to Admin'
  );
  if (!ok) return;

  const r = await fetch('/admin/users/' + _uid + '/role', { method: 'POST' });
  const d = await r.json();
  if (d.success) {
    _uRole = d.role;
    const rb = document.getElementById('umRoleBadge');
    rb.textContent = d.role;
    rb.className   = 'badge ' + (d.role === 'admin' ? 'badge-purple' : 'badge-gray');

    document.getElementById('umRoleLabel').textContent =
      d.role === 'admin' ? 'Demote from Admin' : 'Promote to Admin';

    // Table row badge
    const tb = document.getElementById('urole-' + _uid);
    if (tb) { tb.textContent = d.role; tb.className = 'badge ' + (d.role === 'admin' ? 'badge-purple' : 'badge-gray'); }

    viperToast('Role changed to ' + d.role + '.', 'success');
  } else {
    viperToast(d.error || 'Failed.', 'error');
  }
}

// ── Delete User ──────────────────────────────────────────────────────────────
async function deleteUser() {
  if (!_uid) return;
  const name = document.getElementById('umName').textContent;
  const ok = await viperConfirm(
    'PERMANENTLY delete "' + name + '"? This removes all their data and cannot be undone.',
    'Delete Account'
  );
  if (!ok) return;

  const r = await fetch('/admin/users/' + _uid + '/delete', { method: 'POST' });
  const d = await r.json();
  if (d.success) {
    viperToast('User "' + name + '" deleted.', 'success');
    closeUserModal();
    // Remove row from table
    const row = document.getElementById('urow-' + _uid);
    if (row) row.remove();
  } else {
    viperToast(d.error || 'Failed to delete user.', 'error');
  }
}
</script>
