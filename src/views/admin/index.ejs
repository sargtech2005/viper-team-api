<style>
.admin-main{padding:28px 24px}
@media(max-width:600px){.admin-main{padding:16px}}
.admin-stat{background:var(--bg-card);border:1.5px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center}
.admin-val{font-size:1.9rem;font-weight:900;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.admin-lbl{font-size:.76rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-top:4px}
</style>

<div class="admin-main">
  <%- include('../partials/admin-nav', { adminActive: 'overview' }) %>

  <div class="page-header"><h2>Admin Overview</h2><p>Platform-wide stats and recent signups.</p></div>

  <div class="stats-grid" style="margin-bottom:24px">
    <div class="admin-stat"><div class="admin-val"><%= stats.users %></div><div class="admin-lbl">Total Users</div></div>
    <div class="admin-stat"><div class="admin-val"><%= stats.apiKeys %></div><div class="admin-lbl">Active Keys</div></div>
    <div class="admin-stat"><div class="admin-val">&#8358;<%= Number(stats.revenue||0).toLocaleString() %></div><div class="admin-lbl">Revenue</div></div>
    <div class="admin-stat"><div class="admin-val"><%= Number(stats.apiCalls||0).toLocaleString() %></div><div class="admin-lbl">API Calls</div></div>
  </div>

  <div class="card" style="padding:0">
    <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
      <div style="display:flex;align-items:center;gap:8px">
        <h4>Recent Signups</h4>
        <% if (totalUsersCount > 5) { %><span class="badge badge-gray" style="font-size:.72rem"><%= totalUsersCount %> total</span><% } %>
      </div>
      <a href="/admin/users" class="btn btn-outline btn-sm">View all <%- icon('arrow-right',12) %></a>
    </div>
    <div class="table-wrap"><table>
      <thead><tr><th>#</th><th>Username</th><th>Email</th><th>Role</th><th>Joined</th></tr></thead>
      <tbody>
        <% recentUsers.forEach(u => { %>
        <tr>
          <td style="color:var(--text-muted)">#<%= u.id %></td>
          <td><strong><%= u.username %></strong></td>
          <td style="color:var(--text-muted);font-size:.83rem"><%= u.email %></td>
          <td><span class="badge <%= u.role==='admin'?'badge-purple':'badge-blue' %>"><%= u.role %></span></td>
          <td style="font-size:.76rem;color:var(--text-muted)"><%= new Date(u.created_at).toLocaleDateString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table></div>
    <% if (totalUsersCount > 5) { %>
    <div style="padding:12px 20px;border-top:1px solid var(--border);text-align:center">
      <a href="/admin/users" class="btn btn-outline btn-sm" style="width:100%"><%- icon('users',13) %> View all <%= totalUsersCount %> users</a>
    </div>
    <% } %>
  </div>
</div>
