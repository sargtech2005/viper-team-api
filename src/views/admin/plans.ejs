<style>
.admin-main{padding:28px 24px}
@media(max-width:600px){.admin-main{padding:16px}}
</style>

<div class="admin-main">
  <%- include('../partials/admin-nav', { adminActive: 'plans' }) %>

  <div class="page-header"><h2>Plans</h2><p>Plan configuration. Edit via SQL in the Fly.io Postgres console.</p></div>

  <div class="card" style="padding:0">
    <div class="table-wrap"><table>
      <thead><tr><th>Name</th><th>Price (&#8358;)</th><th>API Limit</th><th>Rate /min</th><th>Status</th></tr></thead>
      <tbody>
        <% plans.forEach(p => { %>
        <tr>
          <td><strong><%= p.name %></strong></td>
          <td>&#8358;<%= p.price_ngn.toLocaleString() %></td>
          <td><%= p.api_limit.toLocaleString() %></td>
          <td><%= p.rate_per_min %></td>
          <td><span class="badge <%= p.is_active?'badge-green':'badge-red' %>"><%= p.is_active?'Active':'Hidden' %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table></div>
  </div>

  <div class="alert alert-info mt-3"><%- icon('info',15) %> To edit plans: <code>fly postgres connect -a viper-db</code> then run SQL UPDATE queries.</div>
</div>
