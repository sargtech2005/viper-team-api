<%- contentFor('style') %>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { adminActive: 'plans' }) %>
  <div class="admin-main">
    <div class="page-header"><h2>Plans</h2><p>Plan configuration. Edit via SQL in the Fly.io Postgres console.</p></div>
    <div class="card" style="padding:0">
      <!-- Desktop table -->
      <div class="table-wrap rwd-table-wrap">
        <table>
          <thead><tr><th>Name</th><th>Price (&#8358;)</th><th>API Limit</th><th>Rate /min</th><th>Status</th></tr></thead>
          <tbody>
            <% plans.forEach(p => { %>
            <tr>
              <td><strong><%= p.name %></strong></td>
              <td>&#8358;<%= p.price_ngn.toLocaleString() %></td>
              <td><%= p.api_limit.toLocaleString() %></td>
              <td><%= p.rate_per_min %></td>
              <td><span class="badge <%= p.is_active?'badge-green':'badge-red' %>"><%= p.is_active?'Active':'Hidden' %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <!-- Mobile cards -->
      <div class="rwd-cards">
        <% plans.forEach(p => { %>
        <div class="rwd-card">
          <div class="rwd-card-row rwd-card-row--between">
            <strong><%= p.name %></strong>
            <span class="badge <%= p.is_active?'badge-green':'badge-red' %>"><%= p.is_active?'Active':'Hidden' %></span>
          </div>
          <div class="rwd-card-row"><span class="rwd-label">Price</span><span>&#8358;<%= p.price_ngn.toLocaleString() %></span></div>
          <div class="rwd-card-row"><span class="rwd-label">API Limit</span><span><%= p.api_limit.toLocaleString() %>/mo</span></div>
          <div class="rwd-card-row"><span class="rwd-label">Rate Limit</span><span><%= p.rate_per_min %> req/min</span></div>
        </div>
        <% }) %>
      </div>
    </div>
    <div class="alert alert-info mt-3"><%- icon('info',15) %> To edit plans: <code>fly postgres connect -a viper-db</code> then run SQL UPDATE queries.</div>
  </div>
</div>
