<style>
/* ── Layout ─────────────────────────────────────────────────────────────── */
.docs-wrap{display:grid;grid-template-columns:260px minmax(0,1fr);min-height:calc(100vh - var(--navbar-h));gap:0;overflow-x:hidden;max-width:100%}
@media(max-width:900px){.docs-wrap{grid-template-columns:minmax(0,1fr)}}

/* ── Sidebar ────────────────────────────────────────────────────────────── */
.docs-sidebar{background:var(--bg-2);border-right:1.5px solid var(--border);padding:20px 12px;position:sticky;top:var(--navbar-h);height:calc(100vh - var(--navbar-h));overflow-y:auto}
@media(max-width:900px){.docs-sidebar{display:none}}
.ds-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);padding:0 8px;margin:20px 0 6px}
.ds-label:first-child{margin-top:0}
.ds-link{display:flex;align-items:center;gap:8px;width:100%;padding:8px 10px;border-radius:var(--radius-sm);color:var(--text-subtle);font-size:.84rem;font-weight:500;border:none;background:none;cursor:pointer;text-align:left;transition:all var(--transition)}
.ds-link:hover,.ds-link.active{background:var(--purple-bg);color:var(--purple)}
.base-box{margin:20px 8px 0;padding:12px 14px;background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm)}
.base-box .bb-label{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-muted);margin-bottom:5px}
.base-box code{font-family:var(--mono);font-size:.72rem;color:var(--purple);word-break:break-all}

/* ── Main — fills column width, no dead zone ────────────────────────────── */
.docs-main{padding:32px 36px;width:100%;min-width:0;overflow-x:hidden}
@media(max-width:1200px){.docs-main{padding:28px 24px}}
@media(max-width:600px){.docs-main{padding:16px 14px}}

/* ── Global API Key Bar ─────────────────────────────────────────────────── */
.global-key-bar{display:flex;align-items:center;gap:10px;background:var(--bg-2);border:1.5px solid var(--border);border-radius:var(--radius);padding:11px 16px;margin-bottom:28px;flex-wrap:wrap;width:100%}
.gk-label{display:flex;align-items:center;gap:6px;font-size:.82rem;font-weight:700;color:var(--text-muted);white-space:nowrap;flex-shrink:0}
.gk-input-wrap{flex:1;min-width:0;display:flex;align-items:center;background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;transition:border-color var(--transition)}
.gk-input-wrap:focus-within{border-color:var(--purple);box-shadow:var(--shadow-glow)}
.gk-input{flex:1;border:none;outline:none;background:transparent;padding:8px 12px;font-family:var(--mono);font-size:.82rem;color:var(--text)}
.gk-input::placeholder{color:var(--text-muted);font-family:var(--font);font-size:.8rem}
.gk-toggle{background:none;border:none;border-left:1.5px solid var(--border);padding:8px 10px;cursor:pointer;color:var(--text-muted);display:flex;align-items:center;transition:color var(--transition);flex-shrink:0}
.gk-toggle:hover{color:var(--purple)}
.apikey-bar{display:flex;align-items:center;gap:10px;background:var(--purple-bg);border:1.5px solid rgba(139,92,246,0.3);border-radius:var(--radius);padding:12px 16px;margin-bottom:28px;flex-wrap:wrap}
.apikey-bar input{flex:1;min-width:0;background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:9px 14px;font-family:var(--mono);font-size:.83rem;color:var(--purple);outline:none;transition:border-color var(--transition)}
.apikey-bar input:focus{border-color:var(--purple);box-shadow:var(--shadow-glow)}
.apikey-bar input::placeholder{color:var(--text-muted);font-family:var(--font)}

/* ── Category section ───────────────────────────────────────────────────── */
.cat-section{margin-bottom:44px}
.cat-hd{display:flex;align-items:center;gap:12px;margin-bottom:18px;padding-bottom:14px;border-bottom:1.5px solid var(--border)}
.cat-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;background:var(--purple-bg);border:1.5px solid rgba(139,92,246,0.25);flex-shrink:0}
.cat-hd h3{font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:2px}
.cat-hd p{font-size:.82rem;color:var(--text-muted)}

/* ── Endpoint accordion ─────────────────────────────────────────────────── */
.ep-card{border:1.5px solid var(--border);border-radius:var(--radius);margin-bottom:10px;overflow:hidden;transition:border-color var(--transition),box-shadow var(--transition)}
.ep-card.open{border-color:var(--purple);box-shadow:0 0 0 3px rgba(139,92,246,0.08)}
.ep-header{display:flex;align-items:center;gap:10px;padding:14px 18px;cursor:pointer;user-select:none;background:var(--bg-card);transition:background var(--transition)}
.ep-header:hover{background:var(--bg-2)}
.ep-body{display:none;border-top:1.5px solid var(--border);background:var(--bg-card)}
.ep-card.open .ep-body{display:block}
/* Method badges — dark-compatible */
.method-badge{font-family:var(--mono);font-size:.67rem;font-weight:800;padding:3px 10px;border-radius:6px;letter-spacing:.04em;flex-shrink:0;white-space:nowrap}
.m-get{background:rgba(16,185,129,0.15);color:#6ee7b7;border:1px solid rgba(16,185,129,0.25)}
.m-post{background:rgba(96,165,250,0.15);color:#93c5fd;border:1px solid rgba(96,165,250,0.25)}
/* Endpoint header — hide name label on very small screens */
.ep-path{font-family:var(--mono);font-size:.8rem;color:var(--text-subtle);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0}
.ep-name{font-size:.87rem;font-weight:600;color:var(--text);white-space:nowrap;flex-shrink:0}
@media(max-width:600px){.ep-name{display:none}}
.ep-chevron{color:var(--text-muted);transition:transform var(--transition);flex-shrink:0}
.ep-card.open .ep-chevron{transform:rotate(180deg)}

/* ── Endpoint body tabs ─────────────────────────────────────────────────── */
.ep-tabs{display:flex;gap:2px;padding:14px 18px 0;border-bottom:1px solid var(--border);background:var(--bg-2);overflow-x:auto}
.ep-tab{padding:7px 14px;font-size:.8rem;font-weight:600;border:none;background:none;cursor:pointer;color:var(--text-muted);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all var(--transition);border-radius:6px 6px 0 0;white-space:nowrap}
.ep-tab.active{color:var(--purple);border-bottom-color:var(--purple);background:rgba(139,92,246,0.08)}
.ep-tab-panel{display:none;padding:18px}
.ep-tab-panel.active{display:block}
@media(max-width:480px){.ep-tab-panel{padding:14px 12px}}

/* ── Params table — scrollable wrapper on mobile ─────────────────────────── */
.p-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;border-radius:var(--radius-sm);border:1.5px solid var(--border)}
.p-table{width:100%;border-collapse:collapse;font-size:.82rem;min-width:480px}
.p-table th{text-align:left;padding:9px 14px;background:var(--bg-3);color:var(--text-muted);font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.p-table td{padding:10px 14px;border-top:1px solid var(--border);vertical-align:top;color:var(--text-subtle);font-size:.83rem}
.p-table td:first-child{font-family:var(--mono);color:var(--purple);font-weight:600}
.req-badge{display:inline-block;font-size:.65rem;font-weight:700;color:var(--red);background:var(--red-bg);padding:1px 6px;border-radius:4px;margin-left:5px}
.opt-badge{display:inline-block;font-size:.65rem;font-weight:700;color:var(--text-muted);background:var(--bg-3);padding:1px 6px;border-radius:4px;margin-left:5px}

/* ── Code Block ─────────────────────────────────────────────────────────── */
.code-block-wrap{border-radius:var(--radius);overflow:hidden;border:1.5px solid #1e293b;box-shadow:0 8px 32px rgba(0,0,0,0.4),0 2px 8px rgba(0,0,0,0.3);margin:0;max-width:100%;width:100%}
.code-block-chrome{display:flex;align-items:center;background:#131d2e;padding:0;border-bottom:1px solid #1e2d45}
.code-chrome-dots{display:flex;align-items:center;gap:6px;padding:10px 14px}
.code-chrome-dots span{width:12px;height:12px;border-radius:50%;display:block}
.ccd-r{background:#ff5f57}.ccd-y{background:#febc2e}.ccd-g{background:#28c840}
.code-chrome-title{flex:1;text-align:center;font-family:var(--mono);font-size:.72rem;color:#64748b;letter-spacing:.05em;padding-right:80px}
.code-copy-btn{margin-left:auto;background:none;border:none;color:#64748b;cursor:pointer;padding:10px 14px;font-size:.75rem;font-family:var(--mono);display:flex;align-items:center;gap:5px;transition:color var(--transition)}
.code-copy-btn:hover{color:#a5b4fc}
.code-copy-btn.copied{color:#34d399}
.code-block-body{background:#0d1117;padding:18px 20px;overflow-x:auto}
.code-block-body pre{margin:0;font-family:var(--mono);font-size:.8rem;line-height:1.75;color:#e2e8f0;white-space:pre;tab-size:2}
.tok-comment{color:#6b7280;font-style:italic}.tok-string{color:#86efac}.tok-keyword{color:#c084fc}
.tok-number{color:#fb923c}.tok-key{color:#93c5fd}.tok-url{color:#34d399;text-decoration:underline}
.tok-method{color:#f472b6;font-weight:700}

/* ── Playground ─────────────────────────────────────────────────────────── */
.playground{background:var(--bg-2);border-radius:var(--radius);padding:18px;border:1.5px solid var(--border)}
.pg-title{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--purple);margin-bottom:14px;display:flex;align-items:center;gap:7px}
.pg-key-row{display:flex;align-items:center;gap:8px;margin-bottom:14px;padding:10px 14px;background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm)}
.pg-key-row label{font-size:.75rem;font-weight:600;color:var(--text-muted);white-space:nowrap}
.pg-key-row input{flex:1;border:none;outline:none;font-family:var(--mono);font-size:.8rem;color:var(--text);background:transparent}
.pg-inputs{display:flex;flex-direction:column;gap:9px;margin-bottom:14px}
.pg-input-wrap{display:flex;flex-direction:column;gap:3px}
.pg-input-label{font-size:.74rem;color:var(--text-muted);font-weight:500}
.pg-input{background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:9px 13px;font-size:.83rem;font-family:var(--mono);color:var(--text);outline:none;width:100%;transition:border-color var(--transition)}
.pg-input:focus{border-color:var(--purple);box-shadow:0 0 0 2px rgba(139,92,246,.12)}
.pg-input::placeholder{color:var(--text-muted)}
.run-btn{display:inline-flex;align-items:center;gap:7px;padding:9px 20px;background:var(--grad);color:#fff;border:none;border-radius:var(--radius-sm);font-size:.84rem;font-weight:600;cursor:pointer;transition:all var(--transition)}
.run-btn:hover:not(:disabled){opacity:.88;transform:translateY(-1px)}
.run-btn:disabled{opacity:.45;cursor:not-allowed;transform:none}
.pg-result{margin-top:14px;display:none}
.pg-result.show{display:block}
.pg-res-hd{display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap}
.pg-status{font-size:.74rem;font-weight:700;padding:2px 9px;border-radius:5px}
.pg-status.ok{background:var(--green-bg);color:#6ee7b7}
.pg-status.err{background:var(--red-bg);color:var(--red)}
.pg-time{font-size:.73rem;color:var(--text-muted);font-family:var(--mono)}
.pg-credits{font-size:.73rem;color:var(--purple);font-family:var(--mono);font-weight:600}
.pg-out-wrap{border-radius:var(--radius-sm);overflow:hidden;border:1.5px solid #1e293b}
.pg-out-chrome{display:flex;align-items:center;gap:6px;background:#131d2e;padding:7px 12px;border-bottom:1px solid #1e2d45}
.pg-out-chrome span{width:10px;height:10px;border-radius:50%}
.pg-out{background:#0d1117;padding:14px;font-family:var(--mono);font-size:.78rem;line-height:1.7;color:#e2e8f0;white-space:pre-wrap;word-break:break-word;max-height:300px;overflow-y:auto}
</style>

<div class="docs-wrap">

  <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
  <aside class="docs-sidebar">
    <div class="ds-label">Getting Started</div>
    <button class="ds-link" onclick="jumpTo('auth-section')"><%- icon('shield',14) %> Authentication</button>
    <button class="ds-link" onclick="jumpTo('errors-section')"><%- icon('alert-circle',14) %> Error Codes</button>

    <div class="ds-label">Categories</div>
    <% const catMeta = {
      'Utility':       {icon:'🔧', id:'cat-utility'},
      'Fun & Random':  {icon:'🎭', id:'cat-fun'},
      'Search & Info': {icon:'🔍', id:'cat-search'},
      'Media & Image': {icon:'🖼️', id:'cat-media'},
    }; %>
    <% catalog.forEach(cat => { const m = catMeta[cat.category] || {icon:'⚡',id:'cat-'+cat.category}; %>
      <button class="ds-link" onclick="jumpTo('<%= m.id %>')"><%= m.icon %> <%= cat.category %></button>
    <% }); %>

    <div class="base-box">
      <div class="bb-label">Auth Header</div>
      <code>X-API-Key: viper_xxxx</code>
    </div>
  </aside>

  <!-- ── Main ───────────────────────────────────────────────────────────── -->
  <main class="docs-main">

    <div class="page-header" style="margin-bottom:24px">
      <h2>API Docs & Playground</h2>
      <p style="color:var(--text-muted);margin-top:4px">Browse every endpoint and test live — paste your API key and run directly in the browser. Each test deducts 1 credit.</p>
    </div>

    <!-- Base URL bar -->
    <div class="apikey-bar">
      <div style="display:flex;align-items:center;gap:6px;font-size:.85rem;font-weight:700;color:var(--purple);white-space:nowrap">
        <%- icon('globe',15) %> Base URL
      </div>
      <code style="flex:1;min-width:0;font-family:var(--mono);font-size:.84rem;color:var(--text);background:var(--bg-3);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:9px 14px;display:block;word-break:break-all;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">https://viper-api.name.ng/api/v1</code>
      <button class="btn btn-outline btn-sm" onclick="copyBaseUrl(this)"><%- icon('copy',14) %> Copy</button>
    </div>

    <!-- Global API key — shared across all playground panels -->
    <div class="global-key-bar">
      <div class="gk-label"><%- icon('key',14) %> API Key</div>
      <div class="gk-input-wrap">
        <input type="password" id="globalApiKey" class="gk-input" placeholder="Paste your Viper API key once — used for all playground tests" autocomplete="off" />
        <button class="gk-toggle" id="gkToggle" onclick="toggleGlobalKey()" title="Show/hide key"><%- icon('eye',14) %></button>
      </div>
    </div>

    <!-- Auth section -->
    <div id="auth-section" class="cat-section">
      <div class="cat-hd">
        <div class="cat-icon">🔐</div>
        <div>
          <h3>Authentication</h3>
          <p>How to pass your API key with every request</p>
        </div>
      </div>
      <p style="font-size:.87rem;color:var(--text-subtle);margin-bottom:16px;line-height:1.7">
        Every API call must include your key either as an <code style="font-family:var(--mono);background:var(--bg-3);padding:1px 6px;border-radius:4px">X-API-Key</code> header
        (recommended) or as a <code style="font-family:var(--mono);background:var(--bg-3);padding:1px 6px;border-radius:4px">?key=</code> query param. Each call deducts 1 credit from your monthly quota.
      </p>
      <div class="code-block-wrap">
        <div class="code-block-chrome">
          <div class="code-chrome-dots"><span class="ccd-r"></span><span class="ccd-y"></span><span class="ccd-g"></span></div>
          <div class="code-chrome-title">authentication.sh</div>
          <button class="code-copy-btn" onclick="copyCode(this)"><%- icon('copy',12) %> Copy</button>
        </div>
        <div class="code-block-body">
<pre><span class="tok-comment"># Option 1 — Header (recommended)</span>
curl -X GET \
  "https://viper-api.name.ng/api/v1/utility/uuid" \
  -H <span class="tok-string">"X-API-Key: viper_your_key_here"</span>

<span class="tok-comment"># Option 2 — Query param</span>
curl "https://viper-api.name.ng/api/v1/utility/uuid<span class="tok-string">?key=viper_your_key</span>"

<span class="tok-comment"># Response headers tell you your remaining quota</span>
<span class="tok-comment"># X-Quota-Remaining: 147</span></pre>
        </div>
      </div>
    </div>

    <!-- ── API Categories ──────────────────────────────────────────────── -->
    <% const catIds = {
      'Utility':       'cat-utility',
      'Fun & Random':  'cat-fun',
      'Search & Info': 'cat-search',
      'Media & Image': 'cat-media',
    }; %>
    <% const catDescs = {
      'Utility':       'General-purpose tools: QR codes, UUIDs, encoding, text analysis and more.',
      'Fun & Random':  'Random jokes, quotes and facts to add fun to any app or bot.',
      'Search & Info': 'Wikipedia summaries, country data and live currency exchange rates.',
      'Media & Image': 'Generate placeholder images and letter avatars on the fly.',
    }; %>

    <% catalog.forEach((cat, ci) => {
       const catId   = catIds[cat.category]   || ('cat-'+ci);
       const catDesc = catDescs[cat.category] || '';
       const catEmoji = (catMeta[cat.category] || {icon:'⚡'}).icon;
    %>
    <div id="<%= catId %>" class="cat-section">
      <div class="cat-hd">
        <div class="cat-icon"><%= catEmoji %></div>
        <div>
          <h3><%= cat.category %></h3>
          <p><%= catDesc %></p>
        </div>
      </div>

      <% cat.endpoints.forEach((ep, ei) => {
        const cardId = 'ep-'+ci+'-'+ei;
      %>
      <div class="ep-card" id="<%= cardId %>">
        <div class="ep-header" onclick="toggleEp('<%= cardId %>')">
          <span class="method-badge <%= ep.method==='GET'?'m-get':'m-post' %>"><%= ep.method %></span>
          <span class="ep-path"><%= ep.path %></span>
          <span class="ep-name"><%= ep.label %></span>
          <svg class="ep-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="ep-body">
          <div class="ep-tabs">
            <button class="ep-tab active" onclick="switchTab('<%= cardId %>','overview',this)">Overview</button>
            <button class="ep-tab" onclick="switchTab('<%= cardId %>','example',this)">Code Example</button>
            <button class="ep-tab" onclick="switchTab('<%= cardId %>','playground',this)">▶ Try it</button>
          </div>

          <!-- Overview tab -->
          <div class="ep-tab-panel active" data-panel="<%= cardId %>-overview">
            <p style="color:var(--text-subtle);font-size:.87rem;line-height:1.7;margin-bottom:16px"><%= ep.desc %></p>
            <% if (ep.params.length > 0) { %>
            <div class="p-table-wrap">
            <table class="p-table">
              <thead>
                <tr><th>Parameter</th><th>Type</th><th>Description</th></tr>
              </thead>
              <tbody>
                <% ep.params.forEach(p => { %>
                <tr>
                  <td><%= p.name %><% if (p.required) { %><span class="req-badge">required</span><% } else { %><span class="opt-badge">optional</span><% } %></td>
                  <td style="color:var(--text-muted);font-family:var(--mono);font-size:.78rem">string</td>
                  <td><%= p.desc %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
            </div>
            <% } else { %>
            <p style="font-size:.83rem;color:var(--text-muted);font-style:italic">No parameters required.</p>
            <% } %>
          </div>

          <!-- Code Example tab -->
          <div class="ep-tab-panel" data-panel="<%= cardId %>-example">
            <div class="code-block-wrap">
              <div class="code-block-chrome">
                <div class="code-chrome-dots"><span class="ccd-r"></span><span class="ccd-y"></span><span class="ccd-g"></span></div>
                <div class="code-chrome-title"><%= ep.path.replace('/api/v1/','') %>.sh</div>
                <button class="code-copy-btn" onclick="copyCode(this)"><%- icon('copy',12) %> Copy</button>
              </div>
              <div class="code-block-body">
<pre><span class="tok-method"><%= ep.method %></span> <span class="tok-url"><%= ep.path %></span>
<span class="tok-key">X-API-Key:</span> <span class="tok-string">viper_your_key_here</span>
<% if (ep.params.length > 0 && ep.method === 'GET') { %><span class="tok-comment">
# Query params:</span>
<% ep.params.forEach(p => { %><span class="tok-comment"># &nbsp; <%= p.name %>=<value>  <% if(!p.required){%>(optional)<% } %></span>
<% }); %><% } %><% if (ep.method === 'POST') { %>
<span class="tok-keyword">Content-Type:</span> <span class="tok-string">application/json</span>

{<% ep.params.forEach((p,pi) => { %>
  <span class="tok-key">"<%= p.name %>"</span>: <span class="tok-string">"<value>"</span><%= pi<ep.params.length-1?',':'' %><% }); %>
}</pre>
<% } else if (ep.params.length === 0) { %>
<pre><span class="tok-comment"># No body or params needed — just the API key</span></pre>
<% } %>
              </div>
            </div>
          </div>

          <!-- Playground tab -->
          <div class="ep-tab-panel" data-panel="<%= cardId %>-playground">
            <div class="playground">
              <div class="pg-title"><%- icon('zap',14) %> Live Playground — 1 credit per run</div>
              <div class="pg-key-row">
                <%- icon('key',13) %>
                <label>API Key</label>
                <input type="password" class="pg-key-input" placeholder="Using global key above — or paste here" autocomplete="off" />
                <button type="button" onclick="togglePgKey(this)" style="background:none;border:none;cursor:pointer;color:var(--text-muted);padding:2px"><%- icon('eye',13) %></button>
              </div>
              <% if (ep.params.length > 0) { %>
              <div class="pg-inputs">
                <% ep.params.forEach(p => { %>
                <div class="pg-input-wrap">
                  <label class="pg-input-label"><%= p.name %><% if(p.required){%> <span style="color:#ef4444;font-size:.7rem">*required</span><%}%></label>
                  <input type="text" class="pg-input" data-param="<%= p.name %>" placeholder="<%= p.desc %>" />
                </div>
                <% }); %>
              </div>
              <% } %>
              <button class="run-btn" onclick="runEndpoint(this,'<%= ep.method %>','<%= ep.path %>')">
                <%- icon('play',14) %> Run Request
              </button>
              <div class="pg-result">
                <div class="pg-res-hd">
                  <span class="pg-status">200 OK</span>
                  <span class="pg-time"></span>
                  <span class="pg-credits"></span>
                </div>
                <div class="pg-out-wrap">
                  <div class="pg-out-chrome">
                    <span style="background:#ff5f57"></span>
                    <span style="background:#febc2e"></span>
                    <span style="background:#28c840"></span>
                    <span style="font-family:var(--mono);font-size:.7rem;color:#64748b;margin-left:8px">response.json</span>
                  </div>
                  <div class="pg-out"></div>
                </div>
              </div>
            </div>
          </div>

        </div><!-- ep-body -->
      </div><!-- ep-card -->
      <% }); // endpoints %>
    </div><!-- cat-section -->
    <% }); // catalog %>

    <!-- Errors section -->
    <div id="errors-section" class="cat-section">
      <div class="cat-hd">
        <div class="cat-icon">⚠️</div>
        <div><h3>Error Codes</h3><p>What each HTTP status means</p></div>
      </div>
      <div class="p-table-wrap">
      <table class="p-table">
        <thead><tr><th>Code</th><th>Name</th><th>Description</th></tr></thead>
        <tbody>
          <tr><td>401</td><td>Unauthorized</td><td>Missing or invalid API key</td></tr>
          <tr><td>403</td><td>Forbidden</td><td>Account suspended or key disabled</td></tr>
          <tr><td>404</td><td>Not Found</td><td>Endpoint does not exist</td></tr>
          <tr><td>429</td><td>Too Many Requests</td><td>Monthly quota exhausted — upgrade your plan</td></tr>
          <tr><td>500</td><td>Server Error</td><td>Upstream error — retry after a moment</td></tr>
        </tbody>
      </table>
      </div>
    </div>

  </main>
</div>

<script>
// ── Helpers ──────────────────────────────────────────────────────────────────
function jumpTo(id){
  const el = document.getElementById(id);
  if(el) el.scrollIntoView({behavior:'smooth',block:'start'});
}

function toggleEp(id){
  const card = document.getElementById(id);
  card.classList.toggle('open');
}

function switchTab(cardId, panel, btn){
  const card = document.getElementById(cardId);
  card.querySelectorAll('.ep-tab').forEach(t=>t.classList.remove('active'));
  card.querySelectorAll('.ep-tab-panel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  const target = card.querySelector(`[data-panel="${cardId}-${panel}"]`);
  if(target) target.classList.add('active');
}

function copyBaseUrl(btn){
  navigator.clipboard.writeText('https://viper-api.name.ng/api/v1').then(()=>{
    btn.textContent='Copied!';
    setTimeout(()=>{ btn.innerHTML='<%- icon("copy",14) %> Copy'; },1500);
  });
}

// ── API Key helpers ──────────────────────────────────────────────────────────
function toggleGlobalKey(){
  const inp = document.getElementById('globalApiKey');
  const btn = document.getElementById('gkToggle');
  if(inp.type === 'password'){
    inp.type = 'text';
    btn.innerHTML = '<%- icon("eye-off",14) %>';
  } else {
    inp.type = 'password';
    btn.innerHTML = '<%- icon("eye",14) %>';
  }
}

function togglePgKey(btn){
  const inp = btn.previousElementSibling;
  inp.type = inp.type === 'password' ? 'text' : 'password';
}

function getApiKey(panel){
  // Use per-endpoint key if filled, otherwise fall back to global key bar
  const local  = panel.querySelector('.pg-key-input')?.value?.trim();
  const global = document.getElementById('globalApiKey')?.value?.trim();
  return local || global || '';
}

// ── Copy code ────────────────────────────────────────────────────────────────
function copyCode(btn){
  const pre = btn.closest('.code-block-wrap').querySelector('pre');
  navigator.clipboard.writeText(pre.innerText).then(()=>{
    btn.innerHTML='<%- icon("check",12) %> Copied!';
    btn.classList.add('copied');
    setTimeout(()=>{
      btn.innerHTML='<%- icon("copy",12) %> Copy';
      btn.classList.remove('copied');
    },2000);
  });
}

// ── Run endpoint (playground) ────────────────────────────────────────────────
async function runEndpoint(btn, method, path){
  const panel  = btn.closest('.ep-tab-panel');
  const result = panel.querySelector('.pg-result');
  const out    = panel.querySelector('.pg-out');
  const status = panel.querySelector('.pg-status');
  const timer  = panel.querySelector('.pg-time');
  const credits= panel.querySelector('.pg-credits');

  const apiKey = getApiKey(panel);
  if(!apiKey){
    result.classList.add('show');
    status.textContent='Error';status.className='pg-status err';
    out.textContent='⚠️ Paste your API key in the key bar at the top of the page, or in the field above.';
    timer.textContent='';credits.textContent='';
    return;
  }

  // Collect params
  const inputs = panel.querySelectorAll('.pg-input[data-param]');
  const params  = {};
  inputs.forEach(i=>{if(i.value.trim()) params[i.dataset.param]=i.value.trim();});

  btn.disabled=true;
  btn.innerHTML='<%- icon("loader",14) %> Running…';

  const start=Date.now();
  try{
    let url = path;
    const headers = {'X-API-Key':apiKey,'Content-Type':'application/json'};
    let opts = {method,headers};

    if(method==='GET' && Object.keys(params).length){
      url += '?'+new URLSearchParams(params).toString();
    } else if(method==='POST'){
      opts.body=JSON.stringify(params);
    }

    const res = await fetch(url,opts);
    const ms  = Date.now()-start;
    let data;
    try{ data=await res.json(); }catch(e){ data={raw: await res.text()}; }

    result.classList.add('show');
    status.textContent = res.status+' '+(res.ok?'OK':'Error');
    status.className   = 'pg-status '+(res.ok?'ok':'err');
    timer.textContent  = ms+'ms';
    const rem = res.headers.get('X-Quota-Remaining');
    credits.textContent = rem!=null ? '● '+rem+' credits left' : '';
    out.textContent    = JSON.stringify(data,null,2);
  }catch(err){
    const ms=Date.now()-start;
    result.classList.add('show');
    status.textContent='Network Error';status.className='pg-status err';
    timer.textContent=ms+'ms';credits.textContent='';
    out.textContent='Error: '+err.message;
  }finally{
    btn.disabled=false;
    btn.innerHTML='<%- icon("play",14) %> Run Request';
  }
}
</script>
