# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Viper-Team API

# ─── Database (Fly.io Postgres) ────────────────────────────────────────────────
DATABASE_URL=postgres://username:password@host:5432/viper_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=another_long_random_secret

# ─── Gmail SMTP (use an App Password, not your real password) ─────────────────
# Go to: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=Viper-Team API <yourmail@gmail.com>

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google reCAPTCHA v2 ──────────────────────────────────────────────────────
# Get keys at: https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=confidencerich97@gmail.com

# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
# Free tier: 1,000 calls/day. Sign up at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ─── Spotify Web API ──────────────────────────────────────────────────────────
# Free, no billing needed. Go to: https://developer.spotify.com/dashboard
# Create an app → copy the Client ID and Client Secret below
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
